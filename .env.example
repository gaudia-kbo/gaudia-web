# ============================================================
# GAUDIA 환경변수 설정
# 이 파일을 .env.local 로 복사하고 값을 채워넣으세요
# .env.local 은 절대 GitHub에 올리면 안됩니다!
# ============================================================

# Supabase (필수)
# Supabase 대시보드 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://여기에_프로젝트_URL.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_anon_public_키_붙여넣기

# 앱 기본 설정
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GAUDIA
